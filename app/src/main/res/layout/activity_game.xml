<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar: Room name + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@color/background_medium"
            android:elevation="4dp">

            <!-- Room name -->
            <TextView
                android:id="@+id/tv_room_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blood_red"
                android:textSize="20sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:text="Входная зона" />

            <!-- Status bars row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- Health -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/health"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_health_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="100%"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_health"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="100"
                        android:progressTint="@color/sanity_high" />
                </LinearLayout>

                <!-- Sanity -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sanity"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_sanity_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="100%"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_sanity"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="100"
                        android:progressTint="@color/sanity_high" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Story text area -->
        <ScrollView
            android:id="@+id/scroll_story"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@color/background_dark">

            <TextView
                android:id="@+id/tv_story_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:text="" />
        </ScrollView>

        <!-- Inventory strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/inventory"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_inventory"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>

        <!-- Exit buttons -->
        <LinearLayout
            android:id="@+id/layout_exits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/background_medium"
            android:gravity="center" />

        <!-- Special action buttons -->
        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Jump-scare overlay -->
    <View
        android:id="@+id/screen_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_dark"
        android:visibility="gone" />

    <!-- Jump-scare text -->
    <TextView
        android:id="@+id/tv_jumpscare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/blood_red"
        android:textSize="28sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:shadowColor="#CC000000"
        android:shadowDx="6"
        android:shadowDy="6"
        android:shadowRadius="12" />

</FrameLayout>
