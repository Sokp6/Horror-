<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/blood_red"
        android:textSize="48sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:gravity="center"
        android:shadowColor="#CC000000"
        android:shadowDx="4"
        android:shadowDy="4"
        android:shadowRadius="8"
        android:layout_marginBottom="16dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Открытый мир • Монстры • Выживание"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <!-- Decorative line -->
    <View
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:background="@color/blood_red_dark"
        android:layout_marginBottom="48dp" />

    <!-- New Game Button -->
    <Button
        android:id="@+id/btn_new_game"
        android:layout_width="260dp"
        android:layout_height="60dp"
        android:text="ИГРАТЬ"
        android:textAllCaps="true"
        android:textSize="20sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:textColor="@color/text_primary"
        android:backgroundTint="@color/blood_red"
        android:layout_marginBottom="24dp"
        android:stateListAnimator="@null" />

    <!-- Exit Button -->
    <Button
        android:id="@+id/btn_exit"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:text="@string/exit"
        android:textAllCaps="true"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:textColor="@color/text_dim"
        android:backgroundTint="@color/background_medium"
        android:stateListAnimator="@null" />

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0 — Horror Game"
        android:textColor="@color/text_dim"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:layout_marginTop="48dp" />

</LinearLayout>
